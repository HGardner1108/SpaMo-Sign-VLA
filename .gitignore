# =============================================================================
# Heavy files - ML models, weights, datasets, features
# These are too large for git. Download/generate them separately.
# =============================================================================

# Pre-trained & fine-tuned model files (~22GB)
models/

# Model checkpoint weights (~5.6GB)
weights/

# Extracted video features (~7.8GB)
features/

# Dataset binary data (~119GB) — keeps dataset/*.py code files tracked
dataset/Phoenix14T/

# Translation pipeline test outputs
Translation_Pipeline/translation_target/

